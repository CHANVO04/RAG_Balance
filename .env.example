# ═══════════════════════════════════════════════════════════════
# RAG_Balance — Environment Variables Template
# ═══════════════════════════════════════════════════════════════
# Hướng dẫn: Copy file này thành `.env` và điền giá trị thật vào.
#   cp .env.example .env
# File `.env` đã được gitignore — KHÔNG commit key thật lên Git.
# ═══════════════════════════════════════════════════════════════

# ── OpenAI API ────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here


# ── Knowledge Graph LLM ───────────────────────────────────────
# Provider: "openai" hoặc "ollama"
KG_LLM_PROVIDER=openai
KG_LLM_MODEL=gpt-4.1-mini

# ── Ollama (nếu dùng KG_LLM_PROVIDER=ollama) ──────────────────
KG_OLLAMA_BASE_URL=http://localhost:11434

# ── Embedding & Models ────────────────────────────────────────
EMBED_MODEL=text-embedding-3-small
IMAGE_VLM_MODEL=gpt-4.1-mini
FORMULA_VLM_MODEL=gpt-4.1-mini

# ── Pipeline Tuning ───────────────────────────────────────────
KG_MODE=light
KG_BATCH_SIZE=6
KG_MAX_CHARS_PER_BATCH=6000
KG_MAX_TRIPLETS=10
KG_CALL_DELAY_SEC=0.1
# KG_INCLUDE_VISUALS=false   # uncomment để bật Formula/Image nodes trong KG

# ── Query Tuning ──────────────────────────────────────────────
IMAGE_RELEVANCE_THRESHOLD=0.6
